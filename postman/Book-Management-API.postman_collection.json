{
  "info": {
    "name": "Book Management",
    "description": "CRUD API for Book Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "bookId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Create Book",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('bookId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Harry Potter\",\n  \"author\": \"J.K. Rowling\",\n  \"isbn\": \"1234567891\",\n  \"publishedDate\": \"1997-06-26\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Create Book - Duplicate ISBN (409)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Harry Potter\",\n  \"author\": \"J.K. Rowling\",\n  \"isbn\": \"1234567891\",\n  \"publishedDate\": \"1997-06-26\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Create Book - Validation error (400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\",\n  \"author\": \"J.K. Rowling\",\n  \"isbn\": \"invalid-isbn\",\n  \"publishedDate\": \"1997-06-26\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Get Book By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Get Book By Id - Not Found (404)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/books/999999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "999999"]
        }
      }
    },
    {
      "name": "Update Book (PUT - full update)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Harry Potter and the Chamber of Secrets\",\n  \"author\": \"J.K. Rowling\",\n  \"isbn\": \"1234567891\",\n  \"publishedDate\": \"1997-06-26\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Patch Book (PATCH - title only)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Harry Potter and the Prisoner of Azkaban\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Delete Book",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    }
  ]
}
